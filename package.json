{
  "name": "p2pass",
  "version": "0.3.2",
  "type": "module",
  "description": "P2Pass — peer-to-peer passkeys, UCANs, OrbitDB registry sync, and Storacha backup (Svelte)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/asabya/p2p-passkeys.git"
  },
  "bugs": {
    "url": "https://github.com/asabya/p2p-passkeys/issues"
  },
  "homepage": "https://github.com/asabya/p2p-passkeys#readme",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev:example": "vite --config examples/svelte/vite.config.js",
    "build:example": "vite build --config examples/svelte/vite.config.js",
    "dev:svelte": "vite --config examples/svelte/vite.config.js",
    "build:svelte": "vite build --config examples/svelte/vite.config.js",
    "dev:react": "vite --config examples/react/vite.config.js",
    "build:react": "vite build --config examples/react/vite.config.js",
    "build:docs": "cd docs-site && npm run build && rm -rf ../docs/guide && cp -r build ../docs/guide",
    "build:demo": "BASE_URL=/p2p-passkeys/demo/ vite build --config examples/svelte/vite.config.js --outDir ../../docs/demo --emptyOutDir",
    "kill:dev": "bash scripts/kill-relay-and-vite.sh",
    "test:e2e": "playwright test",
    "test:e2e:recovery-ipns": "playwright test e2e/recovery-worker.spec.js -g \"(b)\"",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed --project=chromium",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepackage": "node scripts/sync-version.mjs",
    "package": "svelte-package && publint",
    "prepublishOnly": "npm run package",
    "version": "node scripts/sync-version.mjs && git add src/lib/index.js",
    "check": "svelte-check --tsconfig ./jsconfig.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint ."
  },
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "browser": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./signing-preference": {
      "types": "./dist/identity/signing-preference.d.ts",
      "import": "./dist/identity/signing-preference.js",
      "default": "./dist/identity/signing-preference.js"
    },
    "./ui/StorachaFab": {
      "types": "./dist/ui/StorachaFab.svelte.d.ts",
      "svelte": "./dist/ui/StorachaFab.svelte",
      "import": "./dist/ui/StorachaFab.svelte",
      "default": "./dist/ui/StorachaFab.svelte"
    },
    "./ui/StorachaFab.svelte": {
      "types": "./dist/ui/StorachaFab.svelte.d.ts",
      "svelte": "./dist/ui/StorachaFab.svelte",
      "import": "./dist/ui/StorachaFab.svelte",
      "default": "./dist/ui/StorachaFab.svelte"
    }
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.spec.*"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@sveltejs/package": "^2.3.10",
    "@sveltejs/vite-plugin-svelte": "^6.1.4",
    "@tailwindcss/vite": "^4.1.17",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "publint": "^0.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "svelte": "^5.38.7",
    "svelte-check": "^4.3.1",
    "svelte-eslint-parser": "^1.6.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^7.1.12",
    "vite-plugin-node-polyfills": "^0.24.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "14.1.1",
    "@chainsafe/libp2p-noise": "^16.1.4",
    "@chainsafe/libp2p-yamux": "^7.0.4",
    "@helia/ipns": "^8.0.0",
    "@le-space/orbitdb-identity-provider-webauthn-did": "^0.2.13",
    "@libp2p/autonat": "^2.0.38",
    "@libp2p/bootstrap": "^11.0.47",
    "@libp2p/circuit-relay-v2": "^3.2.24",
    "@libp2p/crypto": "^5.1.8",
    "@libp2p/dcutr": "^2.0.38",
    "@libp2p/identify": "^3.0.39",
    "@libp2p/peer-id": "^5.1.9",
    "@libp2p/ping": "^2.0.36",
    "@libp2p/pubsub-peer-discovery": "^11.0.2",
    "@libp2p/webrtc": "^5.2.23",
    "@libp2p/websockets": "^9.2.19",
    "@multiformats/multiaddr": "^12.0.0",
    "@orbitdb/core": "^3.0.2",
    "@storacha/client": "^1.8.21",
    "blockstore-level": "^2.0.1",
    "buffer": "^6.0.3",
    "datastore-level": "^11.0.4",
    "helia": "^5.3.0",
    "ipns": "^10.0.0",
    "iso-webauthn-varsig": "npm:@le-space/iso-webauthn-varsig@^0.1.0",
    "it-length-prefixed-stream": "^2.0.4",
    "libp2p": "^2.9.0",
    "lucide-svelte": "^0.500.0",
    "multiformats": "^13.3.7",
    "orbitdb-relay-pinner": "^0.5.0",
    "orbitdb-storacha-bridge": "^0.4.2",
    "w3name": "^1.1.3"
  },
  "overrides": {
    "picomatch": "4.0.4",
    "@ucanto/interface": "npm:@le-space/ucanto-interface@^11.1.1",
    "@ucanto/core": "npm:@le-space/ucanto-core@^10.5.1",
    "@ucanto/principal": "npm:@le-space/ucanto-principal@^9.1.2",
    "@ucanto/client": "npm:@le-space/ucanto-client@^9.1.1",
    "@ucanto/validator": "npm:@le-space/ucanto-validator@^10.1.1"
  },
  "engines": {
    "node": ">=22"
  }
}
